# Supabase (Postgres only — auth is handled by Clerk)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # server only — all DB access uses this; never exposed to the client

# Postgres direct connection (used by supabase/migrate.mjs only; not used at runtime)
DIRECT_URL=

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Sign-up / access control
SUPER_ADMIN_EMAILS=vansh.sood@everestfleet.in   # comma-separated; flagged super-admin on first login
ALLOWED_EMAIL_DOMAINS=everestfleet.in,everestfleet.com

# Google OAuth (Web client) — per-user Drive/Sheets connection. Values from the OAuth client JSON.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# 32-byte base64 key for encrypting stored refresh tokens at rest
TOKEN_ENCRYPTION_KEY=

# Gemini (Google AI Studio). Rotate across keys to dodge rate limits — add as many as you have.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# (alternatively a single comma-separated pool:)
# GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
