# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — never exposed to the client

# Postgres direct connection (used by supabase/migrate.mjs + seed only; not used at runtime)
DIRECT_URL=

# Seed (used only by supabase/seed.mjs)
SEED_SUPER_ADMIN_EMAIL=vansh.sood@everestfleet.in
SEED_SUPER_ADMIN_PASSWORD=

# Google OAuth (Web client). Values from the OAuth client JSON.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# 32-byte base64 key for encrypting stored refresh tokens at rest
TOKEN_ENCRYPTION_KEY=

# Gemini (Google AI Studio, free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
